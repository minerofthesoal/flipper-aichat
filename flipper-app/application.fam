    fap_description="Chat with a local LLM (LM Studio) over the WiFi Devboard + Tailscale bridge",
    sources=[
        "ai_chat.c",
        "ai_chat_uart.c",
        "ai_chat_protocol.c",
        "ai_chat_chat_view.c",
    ],
)
